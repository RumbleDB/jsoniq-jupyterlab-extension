{
    "compilerOptions": {
        "target": "es2022",
        "lib": [
            "es2022",
            "DOM"
        ],
        "module": "NodeNext",
        "moduleResolution": "NodeNext",
        "sourceMap": true,
        "strict": true,
        "outDir": "dist/lib",
        "rootDir": "src",
        "incremental": true,
        "esModuleInterop": true,
        "skipLibCheck": true
    },
    "ts-node": {
        "esm": true
    },
    "include": [
        "./src/*"
    ]
}