{
    "name": "jsoniq-jupyterlab",
    "version": "1.0.1",
    "description": "JupyterLab extension to support JSONiq magic within python cells. This extension is required to get the JSONiq LSP functionality.",
    "packageManager": "pnpm@10.32.1",
    "main": "dist/lib/plugin.js",
    "scripts": {
        "build:lib": "tsc --sourceMap",
        "build:lib:prod": "tsc",
        "build:labextension": "jupyter labextension build .",
        "build:labextension:dev": "jupyter labextension build --development True .",
        "build": "run-s build:lib copy:assets build:labextension:dev",
        "build:prod": "run-s build:lib:prod copy:assets build:labextension",
        "copy:assets": "shx mkdir -p dist/images && shx cp images/* dist/images/",
        "watch": "run-p watch:src watch:labextension",
        "watch:src": "tsc -w --sourceMap",
        "watch:labextension": "jupyter labextension watch .",
        "link": "jupyter labextension link .",
        "antlr4": "antlr-ng -Dlanguage=TypeScript ./src/grammar/jsoniq.g4",
        "test": "jest"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/RumbleDB/jsoniq-jupyterlab-extension.git"
    },
    "keywords": [
        "jsoniq"
    ],
    "author": "JSONiq Development Team",
    "license": "Apache-2.0",
    "bugs": {
        "url": "https://github.com/RumbleDB/jsoniq-jupyterlab-extension/issues"
    },
    "homepage": "https://github.com/RumbleDB/jsoniq-jupyterlab-extension#readme",
    "dependencies": {
        "@codemirror/lang-python": "^6.2.1",
        "@codemirror/lang-sql": "^6.10.0",
        "@codemirror/language": "^6.12.2",
        "@codemirror/state": "^6.6.0",
        "@jest/globals": "^30.3.0",
        "@jupyterlab/application": "^4.4.6",
        "@jupyterlab/cells": "^4.4.6",
        "@jupyterlab/codemirror": "^4.4.6",
        "@jupyterlab/lsp": "^4.4.6",
        "@jupyterlab/notebook": "^4.4.6",
        "@jupyterlab/ui-components": "^4.4.6",
        "@lezer/highlight": "^1.2.3",
        "@types/codemirror": "^5.60.17",
        "@types/node": "^25.5.0",
        "antlr-ng": "^1.0.10",
        "antlr4ng": "^3.0.16"
    },
    "devDependencies": {
        "@jupyterlab/builder": "^4.4.6",
        "@types/jest": "^30.0.0",
        "jest": "^30.3.0",
        "npm-run-all2": "^8.0.4",
        "shx": "^0.4.0",
        "ts-jest": "^29.4.6",
        "ts-loader": "^9.5.4",
        "typescript": "^5.9.3"
    },
    "files": [
        "dist/lib/",
        "dist/labextension/"
    ],
    "jupyterlab": {
        "extension": true,
        "outputDir": "dist/labextension"
    }
}