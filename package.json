{
    "name": "jsoniq-jupyterlab-extension",
    "version": "1.0.2",
    "description": "JupyterLab extension to support JSONiq magic within python cells. This extension is required to get the JSONiq LSP functionality.",
    "main": "dist/plugin.js",
    "scripts": {
        "build:lib": "tsc --sourceMap",
        "build:lib:prod": "tsc",
        "build:labextension": "uv run jupyter labextension build .",
        "build:labextension:dev": "uv run jupyter labextension build --development True .",
        "build": "run-s build:lib build:labextension:dev",
        "build:prod": "run-s build:lib:prod build:labextension",
        "watch": "run-p watch:src watch:labextension",
        "watch:src": "tsc -w --sourceMap",
        "watch:labextension": "uv run jupyter labextension watch .",
        "link": "uv run jupyter labextension link .",
        "antlr4": "antlr-ng -Dlanguage=TypeScript ./src/grammar/jsoniq.g4",
        "test": "jest"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/DavidBuzatu-Marian/jsoniq-jupyter-plugin-extractors.git"
    },
    "keywords": [
        "jsoniq"
    ],
    "author": "JSONiq Development Team",
    "license": "Apache-2.0",
    "bugs": {
        "url": "https://github.com/DavidBuzatu-Marian/jsoniq-jupyter-plugin-extractors/issues"
    },
    "homepage": "https://github.com/DavidBuzatu-Marian/jsoniq-jupyter-plugin-extractors#readme",
    "dependencies": {
        "@codemirror/lang-python": "^6.2.1",
        "@codemirror/lang-sql": "^6.10.0",
        "@codemirror/language": "^6.12.2",
        "@codemirror/state": "^6.6.0",
        "@jest/globals": "^30.3.0",
        "@jupyterlab/application": "^4.4.6",
        "@jupyterlab/cells": "^4.4.6",
        "@jupyterlab/codemirror": "^4.4.6",
        "@jupyterlab/lsp": "^4.4.6",
        "@jupyterlab/notebook": "^4.4.6",
        "@jupyterlab/ui-components": "^4.4.6",
        "@lezer/highlight": "^1.2.3",
        "@types/codemirror": "^5.60.17",
        "@types/node": "^25.5.0",
        "antlr-ng": "^1.0.10",
        "antlr4ng": "^3.0.16"
    },
    "devDependencies": {
        "@jupyterlab/builder": "^4.4.6",
        "@types/jest": "^30.0.0",
        "jest": "^30.3.0",
        "npm-run-all2": "^8.0.4",
        "ts-jest": "^29.4.6",
        "ts-loader": "^9.5.4",
        "typescript": "^5.9.3"
    },
    "files": [
        "/dist"
    ],
    "jupyterlab": {
        "extension": true,
        "outputDir": "./labextension"
    }
}